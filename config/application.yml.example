# ============================================================
# 外部配置模板 —— 复制为 config/application.yml 并填入真实值。
#
#   cp config/application.yml.example config/application.yml
#
# Spring Boot 启动时会用 config/application.yml 逐项覆盖 jar 内打包的 application.yml,
# 外部有的覆盖、外部没写的沿用 jar 内默认。改完重启即可, 无需重新打包(mvn package)。
# 真实的 config/application.yml 已被 .gitignore 忽略, 不会进版本库 —— 密钥只留在部署机上。
# ============================================================

spring:
  datasource:
    url: jdbc:mysql://<DB_HOST>:3306/ba?useSSL=false&allowPublicKeyRetrieval=true&serverTimezone=Asia/Shanghai
    username: root
    password: <YOUR_DB_PASSWORD>

binance:
  # 本地开发通常需走代理访问币安; VPS 可直连币安则 enabled: false。
  proxy:
    enabled: false
    host: 127.0.0.1
    port: 7897

  # 以下为可选覆盖示例, jar 内已有默认值, 按需取消注释并填入:

  # 中频任务 cron (1h OI + 多空比, 默认每30分钟一轮):
  # schedule:
  #   mid-freq-sync: "0 */30 * * * ?"

  # 多空比采集配置 (period/limit 均可覆盖):
  # lsr:
  #   enabled: true
  #   period: 1h
  #   limit: 30
